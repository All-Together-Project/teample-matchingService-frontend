# Supabase 프로젝트 URL & anon 키
# 1) https://supabase.com 접속 → New Project 생성
# 2) Project Settings → API 메뉴
#    - "Project URL" 값을 VITE_SUPABASE_URL 에 복사
#    - "Project API keys"의 "anon / public" 키를 VITE_SUPABASE_ANON_KEY 에 복사
# 3) SQL Editor 에서 supabase/migrations/*.sql 을 0001 → 0004 순서로 실행
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# 앱 이름
VITE_APP_NAME=ALL투게더
